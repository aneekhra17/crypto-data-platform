{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DatalakeBucketAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::crypto-platform-datalake",
        "arn:aws:s3:::crypto-platform-datalake/*"
      ]
    },
    {
      "Sid": "FirehosePutOnly",
      "Effect": "Allow",
      "Action": ["firehose:PutRecord", "firehose:PutRecordBatch"],
      "Resource": "arn:aws:firehose:us-east-1:186004631943:deliverystream/crypto-prices-fallback"
    }
  ]
}
